Node* createNode(int x) {
    Node* p = new Node();
    if(p == NULL) exit(1);
    else {
        p->data = x;
        p->left = NULL;
        p->right = NULL;
    }
return p;
}
void insertNode (Tree &T, int x) {
    if(T != NULL) {
        if(T->data > x) return insertNode(T->left, x);
        if(T->data < x) return insertNode(T->right, x);
    }
    T = createNode(x);
}
Node* findNode(Tree T, int x) {
    if(T == NULL) return NULL;
    if(T->data > x) return findNode(T->left, x);
    else if(T->data < x) return findNode(T->right ,x);
    else return T;
}

