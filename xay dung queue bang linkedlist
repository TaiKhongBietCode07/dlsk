}
void enqueue(List &q, Node *tmp) {
    if(q.pHead == NULL) {
        q.pHead = tmp;
        q.pTail = tmp;
    }
    else {
        q.pTail->next = tmp;
        q.pTail = tmp;
    }
}
void dequeue(List &q) {
    if(q.pHead == NULL) return;
    Node *tmp = q.pHead;
    q.pHead = q.pHead->next;
    if(q.pHead == NULL) q.pTail = NULL;
    delete tmp;
}
