#include <iostream>
using namespace std;
struct Node {
    int data;
    Node *pNext;
};
struct List {
    Node *pHead;
    Node *pTail;
};
int size (List q) {
    int cnt = 0;
    while(q.pHead != NULL) {q.pHead = q.pHead->next; cnt++; }
    return cnt;
}
